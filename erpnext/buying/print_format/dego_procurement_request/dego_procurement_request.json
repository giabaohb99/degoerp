 "doc_type": "Procurement Request",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 11,
 "html": "<style>\n    .print-format {\n        padding: 5mm 6mm !important;\n        font-family: \"Arial\", sans-serif;\n        font-size: 11px;\n        color: #000;\n        line-height: 1.4;\n    }\n\n    .header-wrapper {\n        position: relative;\n        width: 100%;\n        margin-bottom: 10px;\n        min-height: 50px;\n    }\n\n    .header-company {\n        font-weight: bold;\n        font-size: 12px;\n    }\n\n    .meta-box {\n        position: absolute;\n        top: 0;\n        right: 0;\n        border: 1px solid #000;\n        padding: 4px 8px;\n        font-size: 10px;\n        line-height: 1.5;\n        white-space: nowrap;\n    }\n\n    .title-section {\n        text-align: center;\n        margin-bottom: 15px;\n    }\n\n    .title-main {\n        font-size: 16px;\n        font-weight: bold;\n        text-transform: uppercase;\n        margin-bottom: 3px;\n    }\n\n    .info-section {\n        margin-bottom: 10px;\n    }\n\n    .section-title {\n        font-weight: bold;\n        text-transform: uppercase;\n        background-color: #d9e1f2;\n        padding: 4px 6px;\n        border: 1px solid #000;\n        margin-bottom: 0px;\n    }\n\n    .info-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 8px;\n    }\n\n    .info-table td {\n        border: 1px solid #000;\n        padding: 5px 6px;\n        vertical-align: middle;\n    }\n\n    .items-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 8px;\n        margin-bottom: 10px;\n    }\n\n    .items-table th,\n    .items-table td {\n        border: 1px solid #000;\n        padding: 5px 6px;\n        text-align: center;\n    }\n\n    .items-table th {\n        background-color: #d9e1f2;\n        font-weight: bold;\n    }\n\n    .text-left {\n        text-align: left !important;\n    }\n\n    .text-right {\n        text-align: right !important;\n    }\n\n    .signature-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 20px;\n    }\n\n    .signature-table td {\n        border: none !important;\n        text-align: center;\n        vertical-align: top;\n        padding: 10px;\n        width: 25%;\n    }\n</style>\n\n<div class=\"print-format\">\n    <div class=\"header-wrapper\">\n        <div class=\"header-company\">Mã đơn vị: CÔNG TY TNHH DEGO HOLDING</div>\n        <div class=\"meta-box\">\n            Mẫu: 003/BM/PKT<br>\n            Phiên bản: V1-062025<br>\n            Ngày update: 17/7/2025\n        </div>\n    </div>\n\n    <div class=\"title-section\">\n        <div class=\"title-main\">PHIẾU ĐỀ XUẤT MUA HÀNG HÓA/DỊCH VỤ</div>\n        <div>Số: {{ doc.name }}</div>\n        {% set parsed_date = frappe.utils.getdate(doc.transaction_date or frappe.utils.today()) %}\n        <div>Ngày {{ parsed_date.strftime(\"%d\") }} tháng {{ parsed_date.strftime(\"%m\") }} năm {{\n            parsed_date.strftime(\"%Y\") }}</div>\n    </div>\n\n    <!-- THÔNG TIN CHUNG -->\n    <div class=\"info-section\">\n        <div class=\"section-title\">THÔNG TIN CHUNG</div>\n        <table class=\"info-table\">\n            <tr>\n                <td style=\"width: 20%;\">Người đề xuất:</td>\n                <td style=\"width: 30%; font-weight: bold;\">\n                    {{ frappe.db.get_value(\"User\", doc.requester, \"full_name\") or doc.requester }}\n                </td>\n                <td style=\"width: 20%;\">Chức vụ:</td>\n                <td style=\"width: 30%;\">\n                    {{ frappe.db.get_value(\"Employee\", {\"user_id\": doc.requester}, \"designation\") or \"\" }}\n                </td>\n            </tr>\n            <tr>\n                <td>Hiện công tác tại bộ phận:</td>\n                <td>\n                    {{ frappe.db.get_value(\"Department\", doc.requester_department, \"department_name\") or\n                    doc.requester_department or \"\" }}\n                </td>\n                <td>Trưởng phòng ban/bộ phận:</td>\n                <td>\n                    {% set employee_reports_to = frappe.db.get_value(\"Employee\", {\"user_id\": doc.requester}, \"reports_to\") %}\n                    {% set dept_head_name = \"\" %}\n                    {% if employee_reports_to %}\n                        {% set dept_head_name = frappe.db.get_value(\"Employee\", employee_reports_to, \"employee_name\") %}\n                    {% endif %}\n                    {{ dept_head_name or \"\" }}\n                </td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- MỤC ĐÍCH & NỘI DUNG ĐỀ XUẤT -->\n    <div class=\"info-section\">\n        <div class=\"section-title\">MỤC ĐÍCH & NỘI DUNG ĐỀ XUẤT</div>\n        <table class=\"info-table\">\n            <tr>\n                <td style=\"width: 25%;\">Mục đích mua hàng hoá/dịch vụ:</td>\n                <td style=\"width: 75%;\">{{ doc.title or \"\" }}</td>\n            </tr>\n            <tr>\n                <td>Thời gian cần hàng/dịch vụ:</td>\n                <td>\n                    {% if doc.schedule_date %}\n                    {{ frappe.utils.formatdate(doc.schedule_date) }}\n                    {% endif %}\n                </td>\n            </tr>\n            <tr>\n                <td>Nội dung:</td>\n                <td>{{ doc.remarks or \"\" }}</td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- ITEMS TABLE -->\n    <table class=\"items-table\">\n        <thead>\n            <tr>\n                <th style=\"width: 5%;\">STT</th>\n                <th style=\"width: 30%;\" class=\"text-left\">Tên hàng hoá/dịch vụ</th>\n                <th style=\"width: 15%;\">Mã Hàng</th>\n                <th style=\"width: 10%;\">ĐVT</th>\n                <th style=\"width: 10%;\" class=\"text-right\">Số lượng yêu cầu</th>\n                <th style=\"width: 15%;\" class=\"text-right\">Đơn giá</th>\n                <th style=\"width: 15%;\" class=\"text-right\">Thành tiền</th>\n                <th style=\"width: 15%;\" class=\"text-left\">Ghi chú</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td>{{ loop.index }}</td>\n                <td class=\"text-left\">{{ item.item_name }}</td>\n                <td>{{ item.item_code or \"\" }}</td>\n                <td>{{ item.uom or \"\" }}</td>\n                <td class=\"text-right\">{{ \"{:,}\".format(item.qty | int) }}</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(item.proposed_rate | flt) }}</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(item.amount | flt) }}</td>\n                <td class=\"text-left\">{{ item.other_notes or \"\" }}</td>\n            </tr>\n            {% endfor %}\n            <tr style=\"font-weight: bold;\">\n                <td colspan=\"6\" class=\"text-right\">Tổng cộng</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(doc.total_amount | flt) }}</td>\n                <td></td>\n            </tr>\n            <tr style=\"font-weight: bold;\">\n                <td colspan=\"6\" class=\"text-right\">VAT (8%)</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(doc.total_amount * 0.08 | flt) }}</td>\n                <td></td>\n            </tr>\n            <tr style=\"font-weight: bold; background-color: #f2f2f2;\">\n                <td colspan=\"6\" class=\"text-right\">Tổng cộng thanh toán</td>\n                <td class=\"text-right\">{{ \"{:,.0f}\".format(doc.total_amount * 1.08 | flt) }}</td>\n                <td></td>\n            </tr>\n        </tbody>\n    </table>\n\n    <!-- THÔNG TIN NHÀ CUNG CẤP -->\n    <div class=\"info-section\">\n        <div class=\"section-title\">THÔNG TIN NHÀ CUNG CẤP</div>\n        <table class=\"info-table\">\n            <tr>\n                <td style=\"width: 25%;\">Tên nhà cung cấp:</td>\n                <td style=\"width: 75%;\">{{ doc.supplier_name or \"\" }}</td>\n            </tr>\n            <tr>\n                <td>Mã số thuế:</td>\n                <td>{{ doc.supplier_tax_id or \"\" }}</td>\n            </tr>\n            <tr>\n                <td>Liên hệ:</td>\n                <td>{{ doc.supplier_contact or \"\" }}</td>\n            </tr>\n            <tr>\n                <td>Báo giá đính kèm:</td>\n                <td>\n                    [ ] Có &nbsp;&nbsp;&nbsp;&nbsp; [ ] Không &nbsp;&nbsp;&nbsp;&nbsp; .....\n                </td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- PHẦN DÀNH CHO BỘ PHẬN MUA HÀNG -->\n    <div class=\"info-section\">\n        <div class=\"section-title\">PHẦN DÀNH CHO BỘ PHẬN MUA HÀNG</div>\n        <table class=\"info-table\">\n            <tr>\n                <td style=\"width: 25%;\">Thời gian cần hàng/dịch vụ:</td>\n                <td style=\"width: 75%;\">.....</td>\n            </tr>\n            <tr>\n                <td>Yêu cầu khác (nếu có):</td>\n                <td>.....</td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- XÉT DUYỆT -->\n    <div class=\"info-section\" style=\"margin-top: 20px;\">\n        <div class=\"section-title\">XÉT DUYỆT</div>\n        <table class=\"signature-table\">\n            <tr style=\"font-weight: bold;\">\n                <td>Giám đốc</td>\n                <td>TP/BP mua hàng</td>\n                <td>TP/BP đề xuất</td>\n                <td>Người lập</td>\n            </tr>\n            <tr style=\"font-size: 10px; font-style: italic;\">\n                <td>(Ký, ghi rõ họ tên)</td>\n                <td>(Ký, ghi rõ họ tên)</td>\n                <td>(Ký, ghi rõ họ tên)</td>\n                <td>(Ký, ghi rõ họ tên)</td>\n            </tr>\n            <tr style=\"height: 80px;\">\n                <td></td>\n                <td></td>\n                <td></td>\n                <td></td>\n            </tr>\n        </table>\n    </div>\n</div>",
